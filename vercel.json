{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.8.11",
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/python/:path*",
      "destination": "http://153.75.250.227:8000/api/:path*"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
